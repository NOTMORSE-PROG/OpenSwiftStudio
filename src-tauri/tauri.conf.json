{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenSwiftStudio",
  "version": "0.0.1",
  "identifier": "org.openswiftstudio.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenSwiftStudio",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "fullscreen": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "iOS dev IDE for Windows",
    "longDescription": "Open-source standalone IDE that lets developers build iOS apps from Windows without owning a Mac. Free, Apache-2.0."
  }
}
