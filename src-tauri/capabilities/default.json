{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for OpenSwiftStudio's main window. No auth-requiring permissions are exposed by default. Setup-wizard custom commands are reachable via the invoke_handler whitelist in src/lib.rs and don't need ACL entries here.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://download.swift.org/**" },
        { "url": "https://github.com/dorssel/usbipd-win/releases/**" },
        { "url": "https://github.com/xtool-org/xtool/releases/**" },
        { "url": "https://developer.apple.com/**" }
      ]
    }
  ]
}
